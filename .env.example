# ── Vertex AI Authentication ──
# Paste the full JSON content of your Google Cloud service account key.
# The server writes this to a temp file and sets GOOGLE_APPLICATION_CREDENTIALS automatically.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'

# Google Cloud project ID (defaults to the project_id in the service account JSON)
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI region (defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# ── Optional: Use API key instead of Vertex AI ──
# Set USE_VERTEX_AI=false and provide a Gemini API key to use Google AI Studio instead.
# USE_VERTEX_AI=false
# GEMINI_API_KEY=your-api-key

# ── Optional: Override model names ──
# MODEL_LIVE=gemini-2.0-flash-live-001
# MODEL_TEXT=gemini-2.0-flash
# MODEL_TTS=gemini-2.5-flash-preview-tts
# MODEL_TRANSCRIBE=gemini-2.0-flash
